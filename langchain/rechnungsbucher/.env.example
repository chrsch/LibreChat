# ─── LLM Configuration ──────────────────────────────────────────
# Supported: openai, azure, anthropic
LLM_PROVIDER=openai
# Model name (e.g. gpt-4o, gpt-4o-mini, claude-sonnet-4-20250514)
LLM_MODEL=gpt-4o
# API key for the chosen provider
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=...
# AZURE_OPENAI_DEPLOYMENT=...

# ─── LangSmith Configuration ───────────────────────────────────
# Enable tracing (true/false)
LANGSMITH_TRACING=false
# API endpoint (use https://eu.api.smith.langchain.com for EU region)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=rechnungsbucher

# ─── Collmex API Configuration ─────────────────────────────────
COLLMEX_CUSTOMER_ID=
COLLMEX_USERNAME=
COLLMEX_PASSWORD=
COLLMEX_COMPANY_NR=1
COLLMEX_DEFAULT_TAX_CODE=1600
COLLMEX_DEFAULT_CURRENCY=EUR
COLLMEX_UNKNOWN_VENDOR=9999
COLLMEX_ACCOUNT_HISTORY_YEARS=2
COLLMEX_API_TIMEOUT_MS=30000

# ─── Nextcloud WebDAV Configuration ────────────────────────────
NEXTCLOUD_URL=https://your-nextcloud-host
NEXTCLOUD_USERNAME=
NEXTCLOUD_PASSWORD=
NEXTCLOUD_WEBDAV_PATH=/remote.php/dav/files/your_user
NEXTCLOUD_API_TIMEOUT_MS=30000

# ─── Agent Settings ────────────────────────────────────────────
# Max iterations for the agent loop (default: 100)
AGENT_MAX_ITERATIONS=100
# Verbose LangChain output (true/false)
AGENT_VERBOSE=true
